{
  "name": "myfoodhabits-backend",
  "version": "0.1.0",
  "description": "MyFoodHabits API server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate:up": "dotenv -- node-pg-migrate up",
    "migrate:down": "dotenv -- node-pg-migrate down 1",
    "migrate:create": "node-pg-migrate create --",
    "seed": "node scripts/seed.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.11.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "@types/pg": "^8.11.6",
    "dotenv-cli": "^7.4.2",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "node-pg-migrate": "^7.3.2",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.3.0"
  },
  "engines": {
    "node": ">=22"
  }
}
